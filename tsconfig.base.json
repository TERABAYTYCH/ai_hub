{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@ject-hub/contracts": ["libs/contracts/src/index.ts"],
      "@ject-hub/contracts/hub": ["libs/contracts/src/hub/index.ts"],
      "@ject-hub/contracts/hub/auth": ["libs/contracts/src/hub/auth/index.ts"],
      "@ject-hub/contracts/hub/devices": ["libs/contracts/src/hub/devices/index.ts"]
    },
    "types": ["node", "jest"],
    "typeRoots": ["./node_modules/@types"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
