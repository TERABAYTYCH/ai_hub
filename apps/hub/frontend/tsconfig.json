{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"],
    "baseUrl": "../../../",
    "paths": {
      "@app/contracts": ["libs/contracts/src/index.ts"],
      "@app/contracts/hub": ["libs/contracts/src/hub/index.ts"],
      "@app/contracts/hub/auth": ["libs/contracts/src/hub/auth/index.ts"],
      "@ject-hub/ui-kit": ["libs/ui-kit/src/index.ts"]
    }
  },
  "include": ["src"]
}
